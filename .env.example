# ─────────────────────────────────────────────────────
# Gharauni.com — Environment Variables Template
# Copy to .env.local for dev, set in Vercel dashboard for prod
# ─────────────────────────────────────────────────────

# Site
NEXT_PUBLIC_SITE_URL=https://gharauni.com
NEXT_PUBLIC_SITE_NAME=Gharauni

# Lead capture webhook (n8n / Make / Airtable / Zapier)
# All form submissions POST here. Set up after Phase 4.
LEADS_WEBHOOK_URL=
LEADS_WEBHOOK_SECRET=

# Affiliate tracking IDs (fill as you sign partnerships)
NEXT_PUBLIC_BAJAJ_AFF_ID=
NEXT_PUBLIC_TATA_AFF_ID=
NEXT_PUBLIC_ABFL_AFF_ID=
NEXT_PUBLIC_KOTAK_AFF_ID=
NEXT_PUBLIC_SBI_AFF_ID=
NEXT_PUBLIC_HDFC_AFF_ID=

# Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=gharauni.com
NEXT_PUBLIC_GA_ID=

# SVAMITVA / State Bhulekh API hooks (Phase 4+)
# Currently mocked. Real integration pending data partnerships.
SVAMITVA_API_URL=
SVAMITVA_API_KEY=
UP_BHULEKH_API_URL=
MP_BHULEKH_API_URL=
MH_BHULEKH_API_URL=

# AI / OCR for parser product (Tier 3f)
OPENAI_API_KEY=
GOOGLE_VISION_API_KEY=
